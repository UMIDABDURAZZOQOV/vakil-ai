# Copy this file to .env and fill in real values before running in production.

# Random long string used to sign JWTs. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# SQLite is used out of the box for local development (zero setup).
# Swap to PostgreSQL for production, e.g.:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vakil_ai
DATABASE_URL=sqlite+aiosqlite:///./vakil_ai.db

# Leave empty to run with mocked AI responses. Set this to enable real
# Google Gemini calls for document analysis and chat.
GEMINI_API_KEY=

ACCESS_TOKEN_EXPIRE_MINUTES=10080
FREE_TIER_DOCUMENT_LIMIT=2

# Create a bot with @BotFather on Telegram, then paste the token here and run:
#   python -m app.telegram_bot
# Leave empty and the bot process refuses to start (no crash, just an explanation).
TELEGRAM_BOT_TOKEN=

# Payme Merchant API (test mode uses the Payme sandbox checkout + test cards).
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_TEST_MODE=true

# Click Merchant API.
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

PREMIUM_PRICE_UZS=49000
